A0_PROVIDER=openai-compatible
A0_MODEL=hermes-3-llama-3.1-8b
A0_OPENAI_COMPATIBLE_BASE_URL=http://localhost:8080
A0_OPENAI_COMPATIBLE_API_KEY=local-model
A0_OPENROUTER_ENABLED=false
A0_OPENROUTER_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
A0_LOG_LEVEL=DEBUG
A0_LOG_FILE=~/.a0/logs/agent_zero.log
A0_EXTENSIONS_MEMORIZE_SOLUTIONS=enabled
A0_EXTENSIONS_CODE_GENERATION=enabled
A0_EXTENSIONS_SUMMARIZATION=enabled
A0_REQUEST_TIMEOUT=60
A0_MAX_CONCURRENT=3

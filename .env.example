# Docker Agent Environment Configuration
# Copy to .env and fill in your secrets

# ═════════════════════════════════════════════════════════════════════════════
# NOTION (Required for Présence-Parcours integration)
# ═════════════════════════════════════════════════════════════════════════════

# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# Your database ID (from Notion URL)
NOTION_DATABASE_ID=your_database_id_here

# ═════════════════════════════════════════════════════════════════════════════
# LM STUDIO (Required if LM Studio authentication is enabled)
# ═════════════════════════════════════════════════════════════════════════════

# Get from: LM Studio > Settings > Authentication
# See: https://lmstudio.ai/docs/developer/core/authentication
LM_STUDIO_API_KEY=your_lm_studio_api_key_here

# ═════════════════════════════════════════════════════════════════════════════
# LLAMA.CPP SERVER (Optional - only if llama-server requires auth)
# ═════════════════════════════════════════════════════════════════════════════

# API key for llama.cpp server (llama-server:8080). Most llama.cpp setups
# don't enforce auth, so the default dummy value usually works fine.
# LLAMA_SERVER_API_KEY=sk-local-dummy

# ═════════════════════════════════════════════════════════════════════════════
# FALLBACK PROVIDERS (Optional - only if local model fails)
# ═════════════════════════════════════════════════════════════════════════════

# OpenAI (GPT-4 fallback)
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (Claude fallback)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ═════════════════════════════════════════════════════════════════════════════
# AGENT BEHAVIOR
# ═════════════════════════════════════════════════════════════════════════════

# autonomous = runs scheduled tasks automatically
# interactive = waits for user commands
AGENT_MODE=autonomous

# INFO = normal, DEBUG = verbose
AGENT_LOG_LEVEL=INFO

# ═════════════════════════════════════════════════════════════════════════════
# PATHS (Usually fine as-is)
# ═════════════════════════════════════════════════════════════════════════════

LLM_MODELS_PATH=d:/llm_models
AGENT_MEMORY_PATH=./agent_memory
AGENT_LOGS_PATH=./logs

# Use the pre-built base image for Agent Zero
FROM agent0ai/agent-zero-base:latest

# Set build args and environment variables in one place for better maintainability
ARG BRANCH=local
ARG CACHE_DATE=none
ENV BRANCH=$BRANCH

# Copy in order of frequency of change (stable → changing)
# Filesystem first (changes rarely)
COPY ./docker/run/fs/ /

# Application code last (changes frequently)
COPY ./ /git/agent-zero

# Run all installation steps in a single layer to minimize image size
# Use && to stop on first failure
RUN bash /ins/pre_install.sh $BRANCH && \
    bash /ins/install_A0.sh $BRANCH && \
    bash /ins/install_additional.sh $BRANCH && \
    echo "cache buster $CACHE_DATE" && \
    bash /ins/install_A02.sh $BRANCH && \
    bash /ins/post_install.sh $BRANCH && \
    chmod +x /exe/initialize.sh /exe/run_A0.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh

# Expose ports
EXPOSE 22 80 9000-9009

# Initialize runtime and switch to supervisord
CMD ["/exe/initialize.sh", "$BRANCH"]

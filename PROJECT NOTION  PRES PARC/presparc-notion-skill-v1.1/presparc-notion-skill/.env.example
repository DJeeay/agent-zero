# ============================================================
# .env.example — Présence-Parcours / presparc-notion
# ============================================================
# COPIER ce fichier en .env et renseigner les valeurs réelles.
# NE JAMAIS committer .env dans git.
# Dans Agent Zero : utiliser §§secret(NOM_CLE) pour chaque valeur.
# ============================================================

# --- API Notion ---
NOTION_TOKEN=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NOTION_VERSION=2022-06-28

# --- Bases de données CANONIQUES (privées enseignant) ---
BASE_ELEVES_DB_ID=2e01652eed3f812db522f718ce5e8572
BASE_SEANCES_DB_ID=2e01652eed3f812a9333e21d801ae37e
BASE_OBJECTIFS_DB_ID=2e01652eed3f810ea862e5f232bfb0ce
BASE_COMPTES_RENDUS_DB_ID=2e01652eed3f811f90ead738c9a4b7ac
BASE_ABSENCES_DB_ID=fa3ffb04b9eb4a12bec367a0b119211f

# --- Bases MIROIR (lecture seule — parents) ---
# Ne jamais utiliser ces IDs pour des écritures.
SEANCES_PARENTS_DB_ID=a019acc73f484c19b1a229ae7d720a51
OBJECTIFS_PARENTS_DB_ID=e6cde168ab344401a5d676e3c0d617c5
COMPTES_RENDUS_PARENTS_DB_ID=60687fc910cf463fb0ab02911225fffb
ABSENCES_PARENTS_DB_ID=3b72c831e84742eaa4bd6c46d5876d55

# --- Logging ---
LOG_DIR=/a0/usr/notion-agent/logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# --- Chemins skill ---
SKILL_DIR=/a0/usr/skills/presparc-notion
OUTPUT_DIR=/a0/usr/skills/presparc-notion/output
